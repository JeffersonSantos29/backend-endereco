{
  "name": "backend-endereco",
  "version": "1.0.0",
  "description": "Serviço de backend para CRUD de endereços com rotas protegidas (JWT). Implementa sistema de logs para operações críticas e endpoints de acesso temporário não autenticado.  Tags/Topics para adicionar ao repositório: nodejs express postgresql jwt-authentication docker rest-api backend-challenge",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit",
    "postinstall": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeffersonSantos29/backend-endereco.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JeffersonSantos29/backend-endereco/issues"
  },
  "homepage": "https://github.com/JeffersonSantos29/backend-endereco#readme",
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.6.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2"
  }
}
